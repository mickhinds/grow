# Oura API credentials — get these from https://cloud.ouraring.com/v2/docs
OURA_CLIENT_ID=your_client_id_here
OURA_CLIENT_SECRET=your_client_secret_here

# Flask
FLASK_SECRET_KEY=change_this_to_a_random_string
FLASK_ENV=production

# Database path (relative to project root)
DATABASE_PATH=data/grow.db

# Timezone
TIMEZONE=Europe/Helsinki
